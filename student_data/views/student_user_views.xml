<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="student_user_tree_view" model="ir.ui.view">
        <field name="name">student.user.tree</field>
        <field name="model">student.user</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="mobile"/>
                <field name="otp_verified"/>
            </list>
        </field>
    </record>

    <record id="student_user_form_view" model="ir.ui.view">
        <field name="name">student.user.form</field>
        <field name="model">student.user</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>

                        <field name="name"/>

                        <field name="email"/>

                        <field name="password"/>

                        <field name="mobile"/>

                        <field name="signup_otp"/>

                        <field name="otp_verified"/>

                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="student_user_action" model="ir.actions.act_window">
        <field name="name">Users</field>
        <field name="res_model">student.user</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="student_user_menu"
        parent="student_root_menu"
        name="Users"
        action="student_user_action"/>

</odoo>