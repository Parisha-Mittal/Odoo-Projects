<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="student_data_form_inherit_view" model="ir.ui.view">
        <field name="name">student.data.form.inherit</field>
        <field name="model">student.data</field>
        <field name="inherit_id" ref="student_data.student_data_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='phone']" position="after">
                <field name="guardian_name"/>
                <field name="guardian_phone"/>
                <field name="admission_date"/>
            </xpath>
        </field>
    </record>

</odoo>