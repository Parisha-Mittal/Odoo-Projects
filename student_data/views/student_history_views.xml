<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="student_history_tree_view" model="ir.ui.view">
        <field name="name">student.history.tree</field>
        <field name="model">student.history</field>
        <field name="arch" type="xml">
            <list>
                <field name="student_id"/>
                <field name="action"/>
                <field name="remarks"/>
                <field name="date"/>
            </list>
        </field>
    </record>

    <record id="student_history_form_view" model="ir.ui.view">
        <field name="name">student.history.form</field>
        <field name="model">student.history</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="student_id"/>
                        <field name="action"/>
                        <field name="remarks"/>
                        <field name="date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>