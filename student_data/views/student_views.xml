<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="student_data_tree_view" model="ir.ui.view">
        <field name="name">student.data.tree</field>
        <field name="model">student.data</field>
        <field name="arch" type="xml">
            <list>
                <field name="student_id"/>
                <field name="student_name"/>
                <field name="age"/>
                <field name="student_class"/>
                <field name="stream"/>
                <field name="phone"/>
                <field name="fees_status"
                       widget="badge"
                       decoration-success="fees_status == 'paid'"
                       decoration-danger="fees_status == 'unpaid'"/>
                <field name="exam_result"
                       widget="badge"
                       decoration-success="grade_color == 'excellent'"
                       decoration-info="grade_color == 'good'"
                       decoration-warning="grade_color == 'average'"
                       decoration-primary="grade_color == 'poor'"
                       decoration-danger="grade_color == 'fail'"/>
            </list>
        </field>
    </record>
    <record id="student_data_form_view" model="ir.ui.view">
        <field name="name">student.data.form</field>
        <field name="model">student.data</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_history"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-history">
                            <field
                                name="history_count"
                                widget="statinfo"
                                string="History"/>
                        </button>
                        <button
                            name="action_update_fees"
                            type="object"
                            class="btn btn-primary"
                            style="margin-left:12px;"
                            string="Update Fees">
                            <div class="o_stat_info">
                                <span class="o_stat_text">
                                    Update Fees
                                </span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <field name="student_id" readonly="1"/>
                        <field name="student_name"/>
                        <field name="age"/>
                        <field name="student_class"/>
                        <field name="stream"
                               invisible="student_class != '11'"/>
                        <field name="phone"/>
                        <field name="fees_status"/>
                        <field name="exam_result"
                               widget="badge"
                               readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="student_data_action" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">student.data</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem
        id="student_root_menu"
        name="Student Data"/>
    <menuitem
        id="student_menu"
        name="Students"
        parent="student_root_menu"
        action="student_data_action"/>
</odoo>