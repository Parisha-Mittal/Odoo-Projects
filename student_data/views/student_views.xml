<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_student_tree" model="ir.ui.view">
        <field name="name">student.data.tree</field>
        <field name="model">student.data</field>
        <field name="arch" type="xml">

            <list string="Students">

                <field name="student_name"/>

                <field name="age"/>

                <field name="student_class"/>

                <field name="stream" optional="show"/>

                <field name="phone"/>

                <field name="fees_status"
                       widget="badge"
                       decoration-success="fees_status == 'paid'"
                       decoration-danger="fees_status == 'unpaid'"/>

                <field name="exam_result"
                       widget="badge"
                       decoration-success="exam_result in ('A+','A')"
                       decoration-info="exam_result in ('B+','B')"
                       decoration-warning="exam_result in ('C+','C','D','E')"
                       decoration-danger="exam_result == 'Fail' or fees_status == 'unpaid'"/>

            </list>

        </field>
    </record>


    <record id="view_student_form" model="ir.ui.view">
        <field name="name">student.data.form</field>
        <field name="model">student.data</field>
        <field name="arch" type="xml">

            <form string="Student">

                <sheet>

                    <group>

                        <group>

                            <field name="student_name"/>

                            <field name="age"/>

                            <field name="student_class"/>

                            <field name="stream"
                                   invisible="student_class != '11'"/>

                        </group>

                        <group>

                            <field name="phone"/>

                            <field name="fees_status"/>

                            <field name="exam_result"
                                   readonly="1"/>

                        </group>

                    </group>

                </sheet>

            </form>

        </field>
    </record>

    <record id="action_student_data" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">student.data</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="student_root_menu"
        name="Student Data"
        sequence="10"/>

    <menuitem
        id="student_menu"
        name="Students"
        parent="student_root_menu"
        action="action_student_data"/>

</odoo>